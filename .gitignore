# =====================================================================
# .gitignore
# =====================================================================
# See ``checklist/what_goes_to_github.md`` for the full rationale of
# what belongs in the repo vs. what stays local.
# =====================================================================


# ---------- Python build artefacts ----------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---------- Jupyter ----------
.ipynb_checkpoints/

# ---------- OS ----------
.DS_Store
Thumbs.db

# ---------- IDE ----------
.vscode/
.idea/
*.swp
*~

# ---------- MuJoCo / video outputs ----------
# Generated by make broll (~3 min to regenerate); GitHub caps at 100 MB
# per file so keeping them out is safer than in.
*.mp4
*.gif
# Exception: if you ever ship a final "one-file" presentation video:
!presentation/video.mp4

# ---------- Result artefacts that regenerate cheaply ----------
results/videos/*.mp4
results/data/*.tmp

# Long-horizon weight robustness sweep — regenerated by
# `make results`. Keep the summary.json, drop the per-scene scratch.
results/long_horizon_sweep/*/
!results/long_horizon_sweep/.gitkeep
!results/long_horizon_sweep/summary.json

# ---------- LaTeX build artefacts ----------
*.aux
*.log
*.out
*.toc
*.synctex.gz
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.nav
*.snm
*.vrb
*.fmt


